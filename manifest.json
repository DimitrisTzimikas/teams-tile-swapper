{
  "manifest_version": 3,
  "name": "Teams Tile Swapper",
  "version": "0.1.0",
  "description": "Swap Microsoft Teams participant avatars with a custom image, random cats, or random dogs.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://teams.cloud.microsoft/*",
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*",
    "https://cataas.com/*",
    "https://dog.ceo/*",
    "https://images.dog.ceo/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://teams.cloud.microsoft/*",
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["default.svg"],
      "matches": [
        "https://teams.cloud.microsoft/*",
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*"
      ]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Teams Tile Swapper",
    "default_popup": "options.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  }
}
